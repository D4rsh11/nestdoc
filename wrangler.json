{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "sandbox-website-template",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"main": "./src/api/index.ts",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"assets": {
		"directory": "./dist/client",
		"not_found_handling": "single-page-application",
		"run_worker_first": [
			"/api/*"
		]
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "8flflbi6pyrxcysokfio1rdbq324ril1",
			"database_id": "cc334426-a8f8-48f8-8649-f0ef3b561d43",
			"migrations_dir": "src/api/migrations"
		},
		{
			"binding": "nestdoc_db",
			"database_name": "nestdoc-db",
			"database_id": "9e1b9d1a-07e2-4716-b9c9-5d9b2d35cf4d"
		}
	],
	"r2_buckets": [
		{
			"bucket_name": "8flflbi6pyrxcysokfio1rdbq324ril1",
			"binding": "BUCKET"
		},
		{
			"bucket_name": "nestdoc-bucket",
			"binding": "nestdoc_bucket"
		}
	]
}